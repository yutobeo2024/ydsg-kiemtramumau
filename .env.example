# Copy thành .env.local (dev) hoặc set trực tiếp trên VPS via PM2/systemd.

# Đường dẫn file SQLite. Trên VPS đặt ngoài thư mục code để an toàn khi git pull.
DB_PATH=/var/lib/ydsg/db.sqlite

# Thư mục lưu video bài test. Symlink vào public/uploads/videos để Next.js serve.
VIDEO_DIR=/var/lib/ydsg/videos

# Admin credentials. PHẢI đổi password trước khi deploy production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_strong_password
